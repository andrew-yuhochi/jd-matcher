# Gmail OAuth credentials — download Desktop client JSON from GCP Console
GMAIL_OAUTH_CLIENT_PATH=~/.jd-matcher/credentials.json

# Gmail OAuth token — written automatically by `python -m jd_matcher.auth`
GMAIL_TOKEN_PATH=~/.jd-matcher/tokens.json

# OpenAI API key — used for LLM role-fit scoring (M2+)
OPENAI_API_KEY=sk-...

# SQLite database path
DB_PATH=~/.jd-matcher/jd-matcher.db

# GitHub personal access token (repo scope) — used for gh CLI operations
GH_TOKEN=ghp_...
